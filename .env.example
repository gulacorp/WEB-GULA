# ============================================================
# GULA — Variables de entorno
# Copia este archivo como .env y rellena los valores reales
# NUNCA subas .env a git
# ============================================================

# --- Servidor ---
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# --- Stripe (pagos) ---
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Supabase (base de datos) ---
# https://supabase.com → Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_SECRET_KEY=sb_secret_...

# --- PostHog (analytics) ---
# https://posthog.com → Project Settings
POSTHOG_API_KEY=phc_...
POSTHOG_HOST=https://us.posthog.com

# --- Resend (email transaccional) ---
# https://resend.com → API Keys
RESEND_API_KEY=re_...
FROM_EMAIL=marketing@thegulacorp.com

# --- Google Apps Script (sheets + emails gratuitos) ---
# URL del webhook de tu Apps Script desplegado
APPS_SCRIPT_WEBHOOK_URL=https://script.google.com/macros/s/xxx/exec

# --- Google Maps (ubicación tiendas / delivery radius) ---
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_MAPS_API_KEY=AIza...

# --- Crisp (chat en vivo) ---
# https://crisp.chat → Settings → Website → Integration
CRISP_WEBSITE_ID=xxxx-xxxx-xxxx

# --- PassKit (Apple Wallet) ---
# https://api.passkit.io
PASSKIT_TOKEN=

# --- Google Wallet ---
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_CLASS_ID=gula_loyalty_class_001
GOOGLE_WALLET_SIGNING_KEY=
GOOGLE_WALLET_SIGNING_ALG=HS256
